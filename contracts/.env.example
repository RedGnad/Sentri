PRIVATE_KEY=0x_your_deployer_private_key
AGENT_ADDRESS=0x_your_agent_address
TEE_SIGNER_ADDRESS=0x_selected_0g_provider_tee_signer

# Mainnet uses a separate key/address so Galileo rehearsals cannot
# accidentally spend from the 0G mainnet deployer.
PRIVATE_KEY_MAINNET=0x_your_fresh_mainnet_deployer_private_key
AGENT_ADDRESS_MAINNET=0x_your_mainnet_agent_address

# Optional 0G mainnet real-asset overrides.
# DeployMainnetReal.s.sol defaults to the public Jaine USDC.E/W0G pool.
# ZERO_G_MAINNET_USDCE_ADDRESS=0x1f3AA82227281cA364bFb3d253B0f1af1Da6473E
# ZERO_G_MAINNET_W0G_ADDRESS=0x1Cd0690fF9a693f5EF2dD976660a8dAFc81A109c
# ZERO_G_MAINNET_JAINE_USDCE_W0G_POOL_ADDRESS=0xa9e824Eddb9677fB2189AB9c439238A83695C091
