# Sentri agent runtime — environment template.
# Copy to `.env` (gitignored) and fill in values.

# ──────────── Required ────────────

# Wallet that operates the agent across all vaults. Must:
#   1. Be the address registered as `agent` in the VaultFactory (set at
#      factory deploy; immutable).
#   2. Hold an active Agent INFT minted via AgentINFT.mint(...).
#   3. Be a registered keeper on SentriPriceFeed (`feed.setKeeper(addr, true)`).
#   4. Have ≥ 3 OG on Galileo for gas (faucet: https://faucet.0g.ai).
PRIVATE_KEY=0x

# ──────────── Replay-protected multi-tenant addresses (Galileo testnet) ───
# Defaults are baked into src/constants.ts. Override only if redeployed.

NEXT_PUBLIC_VAULT_FACTORY_ADDRESS=0x3DBc323A0540EB104df2C73f30a12CE2881a98aa
NEXT_PUBLIC_VAULT_IMPLEMENTATION_ADDRESS=0xf4bE6A5ead857F5927490418F2903F8Cc88533d6
NEXT_PUBLIC_AGENT_INFT_ADDRESS=0x1181A8670d5CA9597D60fEf2A571a14C58F33020
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=0xD58b37C4d838aad5E0734ba3F0d34DFA34186d7C
NEXT_PUBLIC_SWAP_PAIR_ADDRESS=0x0BeC7F13a4E9DAc95954EcdF3FF2DABd8279700f
NEXT_PUBLIC_PRICE_FEED_ADDRESS=0x0e75243d34E904Ab925064c8297b36484Ce2aB5E
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0xAcd0cc301eB160aA8C19B02a9Fac9a1967A69bE3
NEXT_PUBLIC_MOCK_WETH_ADDRESS=0x246e6080D736A217C151C3b88890C08e2C249d5E
NEXT_PUBLIC_DEMO_VAULT_ADDRESS=0xB6539EC33a360726ac7E8f053327022AC891E86D

# ──────────── Optional ────────────

# Cycle cadence in milliseconds. Each cycle pushes a fresh price to the
# oracle, then iterates every tracked vault once. Default: 5 min.
# Should be ≥ longest cooldownPeriod across active vaults.
AGENT_INTERVAL_MS=300000

# HTTP port for `pnpm run server`. Render sets PORT automatically.
PORT=8080

# Local cache mirror for portfolio state and audit entries (per-vault).
# /tmp is fine on Render (ephemeral); the canonical record lives on 0G Storage.
SENTRI_CACHE_DIR=/tmp/sentri-cache

# Galileo KV fee auto-estimation can be too low; this explicit fee keeps
# storage-backed audit writes reliable on testnet. Set to 0 to use SDK pricing.
STORAGE_SUBMIT_FEE_WEI=1000000000000000
