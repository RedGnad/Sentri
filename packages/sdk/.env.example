# Sentri agent runtime — environment template.
# Copy to `.env` (which is gitignored) and fill in values.

# ──────────── Required ────────────

# Wallet that operates the agent. Must be the same address that:
#   1. Is registered as `agent` on TreasuryVault (`vault.setAgent(...)`)
#   2. Holds an active Agent INFT (minted via AgentINFT.mint(...))
#   3. Is registered as keeper on SentriPriceFeed (`feed.setKeeper(addr, true)`)
#   4. Has at least 3 OG on Galileo testnet (faucet: https://faucet.0g.ai)
PRIVATE_KEY=0x

# Deployed contract addresses (Galileo testnet, chain 16602).
# These match render.yaml. Defaults baked in `src/constants.ts` if you omit them.
NEXT_PUBLIC_TREASURY_VAULT_ADDRESS=0x286dc3f6b3223053e49665333e11f21cfffb4a5e
NEXT_PUBLIC_AGENT_INFT_ADDRESS=0x0e7e5f1d1b76727428352669c469d6e55d47fc81
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=0x93fd20a13dfcfc129f49d9d04ff8d4fb0a808c17
NEXT_PUBLIC_PRICE_FEED_ADDRESS=0xc9d99f3c3de46d3fd816f0b08dd48b4fba41a711
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0xd23cd7730595486d234e50bb7c97e351860a9add
NEXT_PUBLIC_MOCK_WETH_ADDRESS=0xad67a837b2662118f077ff404827cc82f61d5ccb

# ──────────── Optional ────────────

# Iteration cadence in milliseconds (server.ts setInterval).
# Default 300_000 (5 min). Should be ≥ TreasuryVault.policy.cooldownPeriod.
AGENT_INTERVAL_MS=300000

# HTTP port for `pnpm run server`. Render sets PORT automatically.
PORT=8080

# Local cache mirror for portfolio state and audit entries.
# /tmp is fine on Render (ephemeral); the canonical record lives on 0G Storage.
SENTRI_CACHE_DIR=/tmp/sentri-cache
