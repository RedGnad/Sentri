# Sentri agent runtime — environment template.
# Copy to `.env` (gitignored) and fill in values.

# ──────────── Required ────────────

# Wallet that operates the agent across all vaults. Must:
#   1. Be the address registered as `agent` in the VaultFactory (set at
#      factory deploy; immutable).
#   2. Hold an active Agent INFT minted via AgentINFT.mint(...).
#   3. Be a registered keeper on SentriPriceFeed (`feed.setKeeper(addr, true)`).
#   4. Have ≥ 3 OG on Galileo for gas (faucet: https://faucet.0g.ai).
PRIVATE_KEY=0x

# ──────────── Phase 1 multi-tenant addresses (Galileo testnet) ────────────
# Defaults are baked into src/constants.ts. Override only if redeployed.

NEXT_PUBLIC_VAULT_FACTORY_ADDRESS=0xE3cfFc08a8327b7464168a4C17D5AE609bE75153
NEXT_PUBLIC_VAULT_IMPLEMENTATION_ADDRESS=0x7fDfbee09665fffEB150F500C2CC8326c87B6304
NEXT_PUBLIC_AGENT_INFT_ADDRESS=0x3E74C5820e3DF83C331AC058328Dd18C037E151F
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=0x13173a0F2BB4687F8b601374566649559511D512
NEXT_PUBLIC_SWAP_PAIR_ADDRESS=0x1C8040c84344641cA4ab3CAE44c2B99c9ec1f137
NEXT_PUBLIC_PRICE_FEED_ADDRESS=0xaDb52a49d0398cA048f4027Fe81748Dd666BAfF8
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0x93cA5b6fEA5328FAa0ed4B6Cb6a2E82339558792
NEXT_PUBLIC_MOCK_WETH_ADDRESS=0xF25A225562808a00776aAAD4DFC98c6B48Ad5790
NEXT_PUBLIC_DEMO_VAULT_ADDRESS=0x435946204b818e82C97362F21Ca8B967F5266F83

# ──────────── Optional ────────────

# Cycle cadence in milliseconds. Each cycle pushes a fresh price to the
# oracle, then iterates every tracked vault once. Default: 5 min.
# Should be ≥ longest cooldownPeriod across active vaults.
AGENT_INTERVAL_MS=300000

# HTTP port for `pnpm run server`. Render sets PORT automatically.
PORT=8080

# Local cache mirror for portfolio state and audit entries (per-vault).
# /tmp is fine on Render (ephemeral); the canonical record lives on 0G Storage.
SENTRI_CACHE_DIR=/tmp/sentri-cache
